{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "matchStrings": [
        "selectNode +v(?<currentValue>.+?)\n"
      ],
      "managerFilePatterns": [
        "/(^|/)(npmw|yarnw|nodew)$/"
      ],
      "datasourceTemplate": "node",
      "depNameTemplate": "node"
    },
    {
      "customType": "regex",
      "matchStrings": [
        "selectTool +(?<depName>[^ ]+) +(?<currentValue>.+?)\n"
      ],
      "managerFilePatterns": [
        "/(^|/)(npmw|yarnw|nodew)$/"
      ],
      "datasourceTemplate": "npm"
    }
  ],
  "automerge": true
}
